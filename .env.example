# URL pública do site (obrigatória em produção para retorno do Mercado Pago)
NEXT_PUBLIC_SITE_URL=http://127.0.0.1:3001

# Mercado Pago — Access Token (Produção ou Teste)
MP_ACCESS_TOKEN=

# Senha do painel /admin
ADMIN_PASSWORD=troque-esta-senha

# Postgres (Neon free: https://neon.tech)
DATABASE_URL=

# CJ Dropshipping API
# https://developers.cjdropshipping.com → Get Access-token → Get API Key
CJ_API_KEY=
# ou token já gerado:
CJ_ACCESS_TOKEN=

# Markup do motor (preço calculado)
PRICING_MARKUP=2.3
PRICING_FX_BRL=5.6

# Margem mínima BRL e undercut vs mercado (Mercado Livre)
MIN_MARGIN_BRL=20
MARKET_UNDERCUT_PCT=0.03

# Protege rotas de cron (/api/jobs/*)
CRON_SECRET=troque-um-segredo-longo

# Quantos produtos NOVOS o cron importa por execução (default 5, máx 15)
AUTO_IMPORT_BATCH=5

# Teto de produtos ativos na vitrine (filosofia Capitão: 100–200)
CATALOG_CAP=150

# Upstash Redis (opcional — pedidos/cliques persistentes)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
