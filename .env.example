# URL pública do site (obrigatória em produção para retorno do Mercado Pago)
NEXT_PUBLIC_SITE_URL=http://127.0.0.1:3001

# Mercado Pago — Access Token (Produção ou Teste)
MP_ACCESS_TOKEN=

# Senha do painel /admin
ADMIN_PASSWORD=troque-esta-senha

# Postgres (Neon free: https://neon.tech)
DATABASE_URL=

# CJ Dropshipping API
# https://developers.cjdropshipping.com → Get Access-token → Get API Key
CJ_API_KEY=
# ou token já gerado:
CJ_ACCESS_TOKEN=

# Markup 2.0 = +100% sobre custo+frete+taxas (padrão Capitão)
PRICING_MARKUP=2.0
PRICING_FX_BRL=5.6

# Margem mínima BRL e undercut vs mercado (Mercado Livre)
MIN_MARGIN_BRL=20
MARKET_UNDERCUT_PCT=0.03

# Protege rotas de cron (/api/jobs/*)
CRON_SECRET=troque-um-segredo-longo

# Quantos produtos NOVOS o cron importa por dia (default 12, máx 15)
AUTO_IMPORT_BATCH=12

# Teto de produtos ativos na vitrine (filosofia Capitão: 100–200)
CATALOG_CAP=150

# E-mails da jornada (Resend) — remetente oficial da marca
# Plano free do Resend basta para notificações de rastreio (sem WhatsApp pago)
RESEND_API_KEY=
EMAIL_FROM=Capitão Fantástico <contato@capitaofantastico.com.br>

# Rastreio: só API do CJ (incluída na conta). Sem 17TRACK/AfterShip/Correios scrape.
# Token HMAC dos links "Missão concluída?" (opcional; cai em CRON_SECRET)
# MISSION_SECRET=

# Upstash Redis (opcional — pedidos/cliques persistentes)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
