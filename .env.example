# URL pública do site (obrigatória em produção para retorno do Mercado Pago e SEO)
NEXT_PUBLIC_SITE_URL=https://www.capitaofantastico.com.br

# Google Search Console — meta tag de verificação (opcional)
# GOOGLE_SITE_VERIFICATION=cole_o_codigo_aqui

# Mercado Pago — Access Token (Produção ou Teste)
MP_ACCESS_TOKEN=

# Usuário e senha do painel /admin (estilo Sensor Tattoo Fix)
ADMIN_USERNAME=admin
ADMIN_PASSWORD=troque-esta-senha

# Loja em manutenção (1 = vitrine pública redireciona para /manutencao)
MAINTENANCE_MODE=
# Supabase: Project Settings → Database → Connection string → URI (Transaction pooler)
# Adicione ?sslmode=require no final se faltar.
DATABASE_URL=

# Opcional Supabase: conexão direta para migrations (porta 5432)
# DIRECT_URL=

# Cache do catálogo (grátis): Vercel → Marketplace → Upstash Redis → link ao projeto
# Evita vitrine vazia se Postgres oscilar por segundos.
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# CJ Dropshipping API
# https://developers.cjdropshipping.com → Get Access-token → Get API Key
CJ_API_KEY=
# ou token já gerado:
CJ_ACCESS_TOKEN=

# Markup 2.0 = +100% sobre custo+frete+taxas (padrão Capitão)
PRICING_MARKUP=2.0
PRICING_FX_BRL=5.6

# Margem mínima BRL e undercut vs mercado (Mercado Livre)
MIN_MARGIN_BRL=20
MARKET_UNDERCUT_PCT=0.03

# Protege rotas de cron (/api/jobs/*)
CRON_SECRET=troque-um-segredo-longo

# Teto da vitrine (meta fixa de marketing: 200)
CATALOG_CAP=200

# Quantos produtos NOVOS o cron importa por rodada (máx 30, até encher as vagas)
AUTO_IMPORT_BATCH=20

# E-mails da jornada (Resend) — remetente oficial da marca
# Plano free do Resend basta para notificações de rastreio (sem WhatsApp pago)
RESEND_API_KEY=
EMAIL_FROM=Capitão Fantástico <contato@capitaofantastico.com.br>

# Rastreio: só API do CJ (incluída na conta). Sem 17TRACK/AfterShip/Correios scrape.
# Token HMAC dos links "Missão concluída?" (opcional; cai em CRON_SECRET)
# MISSION_SECRET=

# Upstash Redis (opcional — pedidos/cliques persistentes)
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
